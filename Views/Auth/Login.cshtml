@model StangeCastle.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Entrar no Castelo";
}

<div class="auth-container" style="max-width: 400px; margin: 50px auto; padding: 20px; border: 1px solid #ccc; border-radius: 8px;">
    <h2 class="jacquard-12-regular">Login</h2>
    
    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" style="color: red; margin-bottom: 15px;"></div>

        <div style="margin-bottom: 15px;">
            <label asp-for="Email" class="pixelify-sans"></label>
            <input asp-for="Email" class="form-control" style="width: 100%; padding: 8px;" />
            <span asp-validation-for="Email" style="color: red; font-size: 0.8em;"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label asp-for="Password" class="pixelify-sans"></label>
            <input asp-for="Password" class="form-control" style="width: 100%; padding: 8px;" />
            <span asp-validation-for="Password" style="color: red; font-size: 0.8em;"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label>
                <input asp-for="RememberMe" />
                <span class="pixelify-sans">@Html.DisplayNameFor(m => m.RememberMe)</span>
            </label>
        </div>

        <button type="submit" style="width: 100%; padding: 10px; background-color: #239120; color: white; border: none; cursor: pointer;" class="pixelify-sans">Entrar</button>
    </form>
    
    <div style="margin-top: 15px; text-align: center;">
        <a asp-action="Register" class="pixelify-sans">Ainda não tem a chave? Registre-se.</a>
    </div>
</div>